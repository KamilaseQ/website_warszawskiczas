# ─── Gmail SMTP ─────────────────────────────────────────────────────────
# Identyczne lokalnie i na hostingu. SMTP_PASS = Hasło aplikacji z konta Google
# (nie zwykłe hasło). Generujesz je w: Konto Google → Bezpieczeństwo →
# Hasła aplikacji (wymagane 2FA).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=212.kamiltanski@gmail.com
SMTP_PASS=zmien-na-haslo-aplikacji-16-znakow

# ─── Adresy logiczne (do podmiany jednym ruchem) ────────────────────────
# Zmiana = edycja jednej linii + restart aplikacji. Bez zmian w kodzie.
CONTACT_TO_EMAIL=212.kamiltanski@gmail.com
# Przy Gmail SMTP nadawca MUSI być równy SMTP_USER (Gmail to wymusza).
CONTACT_FROM_EMAIL=212.kamiltanski@gmail.com
CONTACT_FROM_NAME=Warszawski Czas — Formularz

# ─── WhatsApp przez CallMeBot ───────────────────────────────────────────
# Aktywacja (raz, ~2 min):
#   1. Na telefonie z numerem +48 501 747 490 dodaj do kontaktów numer
#      +34 644 51 95 23 (np. jako "CallMeBot").
#   2. Wyślij na ten numer przez WhatsApp wiadomość:
#      I allow callmebot to send me messages
#   3. Bot odpisze API keyem — wklej poniżej.
# Numer telefonu BEZ + na początku.
CALLMEBOT_PHONE=48501747490
CALLMEBOT_APIKEY=zmien-na-klucz-od-callmebot

# ─── Kod dostępu do prywatnej kolekcji ─────────────────────────────────
# Symboliczna bramka — sprawdzana po stronie serwera w /api/private-access.
# Wartość zmieniasz bez deployu (zmiana ENV + restart aplikacji).
# Domyślnie używana wartość fallback w kodzie tylko gdy ENV brakuje.
PRIVATE_COLLECTION_CODE=zmien-na-kod-dostepu
