# ============================================================================
# Zmienne środowiskowe strony Warszawski Czas
# ----------------------------------------------------------------------------
# Strona to aplikacja Next.js (server) na Hostingerze. Maile z formularza
# wysyła serwerowy route `app/api/contact/route.ts` (nodemailer + SMTP poniżej).
# Lead + WhatsApp lecą osobno do aplikacji CMS (NEXT_PUBLIC_CMS_LEAD_URL).
# Te dwa kanały są niezależne — patrz `from-cms/adapters/leads.ts`.
# ============================================================================

# ─── Mailing formularza (SMTP, serwer Next na Hostingerze) ──────────────────
# Skrzynka Hostinger. SMTP_PASS to hasło skrzynki biuro@warszawskiczas.pl.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=biuro@warszawskiczas.pl
SMTP_PASS=<haslo-skrzynki-hostinger>
# Adres(y) powiadomień do butiku (po przecinku). Domyślnie = SMTP_USER.
CONTACT_TO_EMAIL=biuro@warszawskiczas.pl
CONTACT_FROM_EMAIL=biuro@warszawskiczas.pl
CONTACT_FROM_NAME=Warszawski Czas - Formularz

# ─── Adapter CMS (from-cms/mode.ts) ─────────────────────────────────────────
# `mock` (domyślne) — czyta `from-cms/fixtures/products.json`.
# `live` — `getAllProducts()` pobiera produkty z CMS po HTTPS.
# Leady są niezależne od `CMS_MODE`: jeśli `NEXT_PUBLIC_CMS_LEAD_URL` jest
# ustawione, formularze wysyłają realny POST do CMS nawet przy produktach z fixtures.
CMS_MODE=mock
# Tylko przy CMS_MODE=live. Bez końcowego slasha.
CMS_API_URL=https://api.camalio.pl
# Read-only token wygenerowany w panelu CMS dla GitHub Action / build.
# Nigdy nie commituj wypełnionej wartości.
CMS_API_TOKEN=zmien-na-token-z-cms

# Publiczny endpoint leadów. To NIE jest sekret; zabezpieczenia są po stronie CMS:
# CORS allowlist, honeypot, walidacja Zod i rate limit.
NEXT_PUBLIC_CMS_LEAD_URL=https://api.camalio.pl/api/v1/leads

# ─── Asssety obrazów (publiczna domena CDN) ─────────────────────────────────
# Bezwzględne URL-e w `images: []` produktu zwracane przez CMS muszą
# wskazywać na tę domenę (Cloudflare R2 z custom domeną).
NEXT_PUBLIC_CDN_BASE_URL=https://cdn.camalio.pl

# ─── Bramka kodowa Kolekcji Prywatnej (klient-side, teaser only) ────────────
# Walidacja w przeglądarce — to NIE jest zabezpieczenie, tylko bramka
# teaser-owa. Prawdziwa weryfikacja klienta = rozmowa po formularzu rejestracji.
# Domyślny fallback to 'mokotowska2026' jeśli zmienna nie jest ustawiona.
NEXT_PUBLIC_PRIVATE_COLLECTION_CODE=mokotowska2026
