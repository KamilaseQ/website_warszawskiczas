{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "data/**/*.ts",
    "lib/**/*.ts",
    "next.config.js",
    "tailwind.config.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
